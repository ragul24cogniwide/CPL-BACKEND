// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id           String   @id @default(uuid())
  name         String
  jerseyNumber Int?
  battingStyle String
  bowlingStyle String
  role         String
  photoUri     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teams         Team[] @relation("TeamPlayers")
  captainOf     Team[] @relation("TeamCaptain")
  viceCaptainOf Team[] @relation("TeamViceCaptain")
}

model Team {
  id            String   @id @default(uuid())
  name          String
  logoUri       String?
  color         String
  captainId     String?
  viceCaptainId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  players     Player[]     @relation("TeamPlayers")
  captain     Player?      @relation("TeamCaptain", fields: [captainId], references: [id])
  viceCaptain Player?      @relation("TeamViceCaptain", fields: [viceCaptainId], references: [id])
  tournaments Tournament[] @relation("TournamentTeams")
}

model Tournament {
  id        String   @id @default(uuid())
  name      String
  venue     String
  season    String
  organizer String
  logoUri   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams   Team[]  @relation("TournamentTeams")
  matches Match[]
}

model Match {
  id                  String   @id @default(uuid())
  type                String
  tournamentId        String?
  teamAId             String
  teamBId             String
  totalOvers          Int
  status              String
  toss                Json
  innings             Json     @default("[]")
  playingXIA          String[]
  playingXIB          String[]
  currentStrikerId    String?
  currentNonStrikerId String?
  currentBowlerId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tournament Tournament? @relation(fields: [tournamentId], references: [id])
}
